generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Auth & Multi-Tenancy ──

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  passwordHash   String
  role           String   @default("member") // admin | member | auditor | superadmin
  fiscalCode     String?
  cerId          String?
  cer            Cer?     @relation(fields: [cerId], references: [id])
  spidId         String?  @unique // SPID subject identifier
  cieId          String?  @unique // CIE identifier
  authProvider   String   @default("local") // local | spid | cie
  lastLoginAt    DateTime?
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions       Session[]
  votes          BallotCast[]
  invoices       Invoice[]
  meterUploads   MeterUpload[]
  notifications  Notification[]
  pushSubscriptions PushSubscription[]
  dashboardLayout   DashboardLayout?
  payments       Payment[]
  storageObjects StorageObject[]
  importJobs     ImportJob[]
  notificationPreferences NotificationPreference[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  refreshToken String?  @unique
  refreshExpiresAt DateTime?
  ipAddress    String?
  userAgent    String?
  csrfToken    String?
  createdAt    DateTime @default(now())
}

// ── CER (Community) ──

model Cer {
  id              String   @id @default(cuid())
  name            String
  territory       String
  municipality    String
  province        String
  foundedYear     Int
  referenceNote   String?
  cabinaPrimaria  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         Member[]
  users           User[]
  energyReadings  EnergyReading[]
  documents       Document[]
  votes           Vote[]
  announcements   Announcement[]
  gseReports      GseReport[]
  invoices        Invoice[]
  pnrrGrants      PnrrGrant[]
  meterUploads    MeterUpload[]
}

// ── Members ──

model Member {
  id                String   @id @default(cuid())
  name              String
  type              String   // produttore | consumatore | prosumer
  podCode           String   @unique
  energyBalanceKwh  Float
  monthlyBenefitEuro Float
  municipality      String
  joinedAt          String
  cerId             String
  cer               Cer      @relation(fields: [cerId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  incentiveShares   IncentiveShare[]
  meterReadings     MeterReading[]
  invoices          Invoice[]
}

// ── Energy Readings (monthly CER totals) ──

model EnergyReading {
  id                String   @id @default(cuid())
  label             String
  productionKwh     Float
  consumptionKwh    Float
  sharedEnergyKwh   Float
  selfConsumptionPct Float
  savingsEuro       Float
  gseIncentiveEuro  Float
  co2AvoidedKg      Float
  cerId             String
  cer               Cer      @relation(fields: [cerId], references: [id])
  createdAt         DateTime @default(now())
}

// ── Smart Meter Readings (per-POD, granular) ──

model MeterReading {
  id            String   @id @default(cuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  timestamp     DateTime
  consumptionKwh Float
  productionKwh  Float
  source        String   @default("csv") // csv | api | manual
  validated     Boolean  @default(false)
  anomaly       String?
  uploadId      String?
  upload        MeterUpload? @relation(fields: [uploadId], references: [id])
  createdAt     DateTime @default(now())
}

model MeterUpload {
  id            String   @id @default(cuid())
  fileName      String
  recordCount   Int
  validCount    Int
  anomalyCount  Int
  status        String   @default("processing") // processing | completed | failed
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  cerId         String
  cer           Cer      @relation(fields: [cerId], references: [id])
  readings      MeterReading[]
  createdAt     DateTime @default(now())
}

// ── Incentive Distribution ──

model IncentiveShare {
  id            String   @id @default(cuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  period        String
  sharePct      Float
  monthlyEuro   Float
  yearToDateEuro Float
  createdAt     DateTime @default(now())
}

// ── Documents ──

model Document {
  id        String   @id @default(cuid())
  title     String
  category  String   // statuto | regolamento | verbale | report
  status    String   // approvato | in_revisione | da_firmare
  owner     String
  fileUrl   String?
  signedAt  DateTime?
  cerId     String
  cer       Cer      @relation(fields: [cerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Voting ──

model Vote {
  id            String       @id @default(cuid())
  title         String
  description   String?
  options       String       // JSON array of options
  voteType      String       @default("open") // open | secret
  quorum        String
  scheduledAt   String
  closesAt      String?
  status        String       @default("programmata") // programmata | aperta | chiusa | annullata
  cerId         String
  cer           Cer          @relation(fields: [cerId], references: [id])
  ballots       BallotCast[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model BallotCast {
  id        String   @id @default(cuid())
  voteId    String
  vote      Vote     @relation(fields: [voteId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  choice    String
  createdAt DateTime @default(now())

  @@unique([voteId, userId])
}

// ── Announcements ──

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String
  publishedAt String
  cerId       String
  cer         Cer      @relation(fields: [cerId], references: [id])
  createdAt   DateTime @default(now())
}

// ── GSE Reporting ──

model GseReport {
  id                 String   @id @default(cuid())
  period             String
  sharedEnergyKwh    Float
  totalIncentiveEuro Float
  status             String   @default("bozza") // bozza | validato | inviato | approvato
  reportData         String?  // JSON with full report details
  submittedAt        DateTime?
  cerId              String
  cer                Cer      @relation(fields: [cerId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Financial / Billing ──

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  cerId           String
  cer             Cer      @relation(fields: [cerId], references: [id])
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  period          String
  amountEuro      Float
  status          String   @default("emessa") // emessa | pagata | scaduta
  dueDate         String
  paidAt          DateTime?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        Payment[]
}

// ── PNRR Grants ──

model PnrrGrant {
  id                String   @id @default(cuid())
  title             String
  eligibleBudgetEuro Float
  approvedEuro      Float
  disbursedEuro     Float
  progressPct       Float
  nextMilestone     String?
  cerId             String
  cer               Cer      @relation(fields: [cerId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Audit Log ──

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}

// ══════════════════════════════════════════════════════
// ── Iteration 2 Models ──
// ══════════════════════════════════════════════════════

// ── Energy Forecasting (Feature 2) ──

model EnergyForecast {
  id               String   @id @default(cuid())
  cerId            String
  forecastType     String   // production | consumption | shared_energy
  periodStart      String
  periodEnd        String
  forecastedKwh    Float
  confidenceLow    Float
  confidenceHigh   Float
  actualKwh        Float?
  accuracy         Float?
  model            String   @default("linear_seasonal")
  weatherData      String?  // JSON: temperature, cloud cover, irradiance
  createdAt        DateTime @default(now())
}

model WeatherCache {
  id          String   @id @default(cuid())
  latitude    Float
  longitude   Float
  date        String
  tempC       Float
  cloudCover  Float
  irradiance  Float
  source      String   @default("open-meteo")
  fetchedAt   DateTime @default(now())

  @@unique([latitude, longitude, date])
}

// ── P2P Energy Trading (Feature 5) ──

model EnergyOffer {
  id            String   @id @default(cuid())
  sellerId      String
  sellerName    String
  cerId         String
  kwh           Float
  pricePerKwh   Float
  minPrice      Float?
  validFrom     String
  validTo       String
  status        String   @default("open") // open | matched | expired | cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades        TradeMatch[]
}

model TradeMatch {
  id            String   @id @default(cuid())
  offerId       String
  offer         EnergyOffer @relation(fields: [offerId], references: [id])
  buyerId       String
  buyerName     String
  kwhTraded     Float
  pricePerKwh   Float
  totalEuro     Float
  status        String   @default("pending") // pending | settled | disputed
  settledAt     DateTime?
  createdAt     DateTime @default(now())
}

model TradingAccount {
  id            String   @id @default(cuid())
  memberId      String   @unique
  memberName    String
  balanceEuro   Float    @default(0)
  totalBought   Float    @default(0)
  totalSold     Float    @default(0)
  totalKwhBought Float   @default(0)
  totalKwhSold  Float    @default(0)
  updatedAt     DateTime @updatedAt
}

// ── Document Generation & E-Signature (Feature 6) ──

model DocumentTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String   // atto_constitutivo | statuto | regolamento | verbale | contratto_adesione
  content       String   // Template with {{placeholders}}
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generated     GeneratedDocument[]
}

model GeneratedDocument {
  id            String   @id @default(cuid())
  templateId    String
  template      DocumentTemplate @relation(fields: [templateId], references: [id])
  cerId         String
  title         String
  content       String
  status        String   @default("draft") // draft | review | signing | signed | archived
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  signatures    SignatureRequest[]
}

model SignatureRequest {
  id            String   @id @default(cuid())
  documentId    String
  document      GeneratedDocument @relation(fields: [documentId], references: [id])
  signerName    String
  signerEmail   String
  status        String   @default("pending") // pending | sent | signed | rejected
  signedAt      DateTime?
  otpCode       String?
  otpExpiresAt  DateTime?
  createdAt     DateTime @default(now())
}

// ── Gamification (Feature 7) ──

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  icon        String   @default("🏆")
  category    String   // energy | community | environment | consistency
  criteria    String   // JSON: { type, threshold, ... }
  points      Int      @default(10)
  createdAt   DateTime @default(now())

  earned      MemberAchievement[]
}

model MemberAchievement {
  id            String   @id @default(cuid())
  memberId      String
  memberName    String
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime @default(now())
  notified      Boolean  @default(false)

  @@unique([memberId, achievementId])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // reduction | shift | production
  targetValue Float
  unit        String   @default("kWh")
  startDate   String
  endDate     String
  status      String   @default("active") // active | completed | expired
  cerId       String
  createdAt   DateTime @default(now())

  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id            String   @id @default(cuid())
  challengeId   String
  challenge     Challenge @relation(fields: [challengeId], references: [id])
  memberId      String
  memberName    String
  currentValue  Float    @default(0)
  completed     Boolean  @default(false)
  joinedAt      DateTime @default(now())

  @@unique([challengeId, memberId])
}

// ── Open API & Webhooks (Feature 8) ──

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  keyPrefix   String   // First 8 chars for display
  scopes      String   // JSON array of allowed scopes
  rateLimit   Int      @default(100) // requests per minute
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())

  usageLogs   ApiUsageLog[]
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  endpoint  String
  method    String
  status    Int
  latencyMs Int
  createdAt DateTime @default(now())
}

model WebhookSubscription {
  id          String   @id @default(cuid())
  url         String
  events      String   // JSON array of event types
  secret      String   // For payload signing
  isActive    Boolean  @default(true)
  createdBy   String
  failCount   Int      @default(0)
  lastDelivery DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries  WebhookDelivery[]
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id])
  event           String
  payload         String   // JSON
  status          String   @default("pending") // pending | delivered | failed
  responseCode    Int?
  attempts        Int      @default(0)
  nextRetry       DateTime?
  createdAt       DateTime @default(now())
}

// ── Carbon Credit Marketplace (Feature 9) ──

model CarbonCredit {
  id              String   @id @default(cuid())
  cerId           String
  cerName         String
  vintage         String   // Year of emission avoidance
  co2Tonnes       Float
  methodology     String   @default("ISO-14064")
  verificationStatus String @default("pending") // pending | verified | certified | retired
  registryId      String?  // External registry reference
  pricePerTonne   Float?
  status          String   @default("available") // available | reserved | sold | retired
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    CarbonTransaction[]
}

model CarbonTransaction {
  id          String   @id @default(cuid())
  creditId    String
  credit      CarbonCredit @relation(fields: [creditId], references: [id])
  buyerName   String
  buyerType   String   // business | individual | municipality
  tonnes      Float
  pricePerTonne Float
  totalEuro   Float
  status      String   @default("pending") // pending | completed | cancelled
  certificateId String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ── Multi-Language (Feature 10) ──

model TranslationKey {
  id          String   @id @default(cuid())
  key         String   @unique
  namespace   String   @default("common") // common | dashboard | auth | energy | billing
  description String?
  createdAt   DateTime @default(now())

  translations Translation[]
}

model Translation {
  id            String   @id @default(cuid())
  keyId         String
  translationKey TranslationKey @relation(fields: [keyId], references: [id])
  locale        String   // it | es | fr | en
  value         String
  isVerified    Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  @@unique([keyId, locale])
}

model CountryConfig {
  id                  String   @id @default(cuid())
  countryCode         String   @unique // IT | ES | FR
  countryName         String
  incentiveFormula    String   // JSON: formula definition
  reportingFormat     String   // GSE | CNMC | ENEDIS
  gridEmissionFactor  Float    // gCO2/kWh
  regulatoryReference String
  currency            String   @default("EUR")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ══════════════════════════════════════════════════════
// ── Iteration 3 Models ──
// ══════════════════════════════════════════════════════

// ── Notifications (Feature 6) ──

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // vote_opened | invoice_due | anomaly_detected | trade_matched | achievement_earned | document_signed
  title     String
  body      String
  actionUrl String?
  read      Boolean  @default(false)
  channel   String   @default("in_app") // in_app | push | email
  cerId     String?
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  category  String   // billing | voting | energy | trading | governance | gamification
  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

// ── Payments (Feature 5) ──

model Payment {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  provider        String   // stripe | pagopa | manual
  providerPaymentId String? // Stripe payment_intent ID or PagoPA IUV
  amount          Float
  currency        String   @default("EUR")
  status          String   @default("pending") // pending | processing | succeeded | failed | refunded
  paymentMethod   String?  // card | sepa_debit | pagopa_notice
  receiptUrl      String?
  refundedAt      DateTime?
  failureReason   String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentMandate {
  id              String   @id @default(cuid())
  memberId        String
  provider        String   // stripe
  providerMandateId String?
  type            String   // sepa_debit
  status          String   @default("pending") // pending | active | cancelled | failed
  bankLast4       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── File Storage (Feature 7) ──

model StorageObject {
  id          String   @id @default(cuid())
  key         String   @unique
  bucket      String   @default("energia-nostra")
  fileName    String
  mimeType    String
  sizeBytes   Int
  category    String   // atti | verbali | fatture | report | contatori | contratti | profile
  cerId       String?
  uploadedBy  String
  user        User     @relation(fields: [uploadedBy], references: [id])
  version     Int      @default(1)
  parentId    String?  // For versioning - points to original
  isPublic    Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Data Import (Feature 9) ──

model ImportJob {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  cerId         String
  type          String   // members | energy_data | financial
  fileName      String
  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  successRows   Int      @default(0)
  errorRows     Int      @default(0)
  status        String   @default("pending") // pending | mapping | validating | importing | completed | failed | rolled_back
  columnMapping String?  // JSON: { sourceColumn: targetField }
  errors        String?  // JSON array of row errors
  rollbackData  String?  // JSON for undo capability
  dryRun        Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Dashboard Customization (Feature 10) ──

model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  layout    String   // JSON: array of widget configs { id, type, position, size, visible, config }
  tourCompleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Observability (Feature 8) ──

model HealthMetric {
  id          String   @id @default(cuid())
  route       String
  method      String
  statusCode  Int
  latencyMs   Int
  errorMessage String?
  userId      String?
  traceId     String?
  createdAt   DateTime @default(now())
}

// ── Events (Feature 4) ──

model DomainEvent {
  id          String   @id @default(cuid())
  type        String   // vote.cast | trade.matched | meter.uploaded | anomaly.detected | invoice.generated | achievement.earned | document.signed
  payload     String   // JSON
  cerId       String?
  userId      String?
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
